{
  "$schema": "https://unpkg.com/release-it/schema/release-it.json",
  "github": {
    "release": true,
    "releaseName": "${version}"
  },
  "git": {
    "commitMessage": "Release ${version}",
    "tagName": "${version}",
    "requireCleanWorkingDir": true
  },
  "npm": {
    "publish": false
  },
  "plugins": {}
}
